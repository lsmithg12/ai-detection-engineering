(winlog.event_data.TargetImage="*\\lsass.exe" winlog.event_data.GrantedAccess IN ("*0x1010*", "*0x1410*", "*0x1438*", "*0x143a*", "*0x1fffff*", "*0x1F0FFF*", "*0x1F1FFF*", "*0x40*", "*0x1400*", "*0x100000*")) OR (file.name="*lsass*" file.extension="dmp") OR file.path="*lsass.dmp*" OR (process.command_line="*lsass*" process.executable IN ("*\\AppData\\*", "*\\Temp\\*", "*\\ProgramData\\*", "*\\Users\\Public\\*")) NOT (process.executable IN ("*\\Microsoft\\Windows Defender\\*", "*\\Windows Defender Advanced Threat Protection\\*") OR process.executable IN ("*\\CrowdStrike\\*", "*\\SentinelOne\\*", "*\\Carbon Black\\*", "*\\Symantec\\*", "*\\Trend Micro\\*", "*\\ESET\\*", "*\\Sophos\\*", "*\\Cybereason\\*", "*\\Cylance\\*") OR process.executable IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\WinSxS\\*") OR process.executable="*\\VMware\\*" OR winlog.event_data.GrantedAccess="0x1000") | table process.executable,process.command_line,file.name,file.path,winlog.event_data.TargetImage,winlog.event_data.GrantedAccess,winlog.event_data.CallTrace,user.name,winlog.event_data.SourceProcessGUID