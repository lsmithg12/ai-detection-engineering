(event.code="10" target.process.executable="*\\lsass.exe" winlog.event_data.GrantedAccess IN ("*0x1010*", "*0x1410*", "*0x1438*", "*0x143a*", "*0x1fffff*", "*0x1F0FFF*", "*0x1F1FFF*", "*0x40*", "*0x1400*", "*0x100000*") NOT (process.executable IN ("*\\Microsoft\\Windows Defender\\*", "*\\Windows Defender Advanced Threat Protection\\*") OR process.executable IN ("*\\CrowdStrike\\*", "*\\SentinelOne\\*", "*\\Carbon Black\\*", "*\\Symantec\\*", "*\\Trend Micro\\*", "*\\ESET\\*", "*\\Sophos\\*", "*\\Cybereason\\*", "*\\Cylance\\*") OR process.executable IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\WinSxS\\*") OR process.executable="*\\VMware\\*" OR winlog.event_data.GrantedAccess="0x1000")) OR (event.code="1" process.executable IN ("*\\AppData\\*", "*\\Temp\\*", "*\\ProgramData\\*", "*\\Users\\Public\\*") process.command_line="*lsass*") OR (event.code="11" file.name="*lsass*") | table event.code,process.executable,process.command_line,target.process.executable,winlog.event_data.GrantedAccess,winlog.event_data.CallTrace,file.name,file.path,user.name,winlog.event_data.SourceProcessGUID