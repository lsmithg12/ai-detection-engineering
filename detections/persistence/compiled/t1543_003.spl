process.name="sc.exe" process.command_line="*create*" process.command_line IN ("*\\AppData\\*", "*\\Users\\Public\\*", "*\\Temp\\*", "*\\ProgramData\\*", "*\\Downloads\\*", "*\\Desktop\\*", "*\\Documents\\*", "*%APPDATA%*", "*%TEMP%*", "*%USERPROFILE%*") NOT ((process.parent.name IN ("msiexec.exe", "setup.exe", "TiWorker.exe", "TrustedInstaller.exe") user.name="SYSTEM") OR process.parent.executable="*\\ccmexec*") | table process.command_line,process.parent.name,process.parent.executable,user.name,host.name