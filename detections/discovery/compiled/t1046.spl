process.executable IN ("*AppData\\Local\\Temp*", "*AppData\\Roaming*", "*ProgramData*", "*Windows\\Temp*", "*Users\\Public*") process.command_line IN ("*--ports*", "*--scan*", "*-p *", "*/scan*", "*--top-ports*", "*-sS*", "*-sT*", "*-sV*", "*-sC*") NOT (process.executable IN ("*Program Files*", "*Program Files (x86)*")) | table process.executable,process.command_line,process.parent.executable,user.name,host.name,process.pid