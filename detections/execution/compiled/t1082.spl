Image="*\\cmd.exe" CommandLine="*/c*" CommandLine="*systeminfo*" CommandLine IN ("*whoami*", "*hostname*", "*ipconfig*", "*net config*", "*wmic os*") NOT (ParentImage IN ("C:\\Program Files\\*", "C:\\Program Files (x86)\\*", "C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\ProgramData\\Microsoft\\Windows Defender\\*")) NOT User="*SYSTEM*" | table CommandLine,ParentImage,ParentCommandLine,User,host.name