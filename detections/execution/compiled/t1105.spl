(event.code="11" file.extension IN ("exe", "dll", "scr", "cpl") file.path IN ("*\\ProgramData\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*", "*\\Temp\\*")) OR (event.code="3" network.direction="egress") OR event.code="1" process.executable IN ("*\\ProgramData\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*", "*\\Temp\\*") NOT (process.executable IN ("*\\Program Files\\*", "*\\Program Files (x86)\\*")) NOT (process.executable IN ("*\\Windows\\System32\\*", "*\\Windows\\SysWOW64\\*", "*\\Windows\\WinSxS\\*")) NOT (process.name IN ("msiexec.exe", "TiWorker.exe", "TrustedInstaller.exe")) | table event.code,process.executable,process.command_line,file.path,file.name,destination.ip,destination.port,user.name,host.name