Image="*\\cmd.exe" (CommandLine="*/c*" CommandLine="*&*" CommandLine IN ("*whoami*", "*net user*", "*net localgroup*", "*nltest*", "*net group*", "*systeminfo*", "*tasklist*", "*query user*", "*net view*", "*netstat*", "*reg query*", "*wmic*") NOT (ParentImage IN ("C:\\Program Files\\*", "C:\\Program Files (x86)\\*"))) OR (ParentImage IN ("*\\ProgramData\\*", "*\\AppData\\*", "*\\Temp\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*", "*\\Downloads\\*", "*\\Recycle*") NOT (ParentImage IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\explorer.exe*")) NOT (ParentImage IN ("*\\explorer.exe", "*\\msiexec.exe", "*\\services.exe"))) | table CommandLine,ParentImage,ParentCommandLine,User,Image