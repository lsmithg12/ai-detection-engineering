(event.category:process AND event.type:start AND (process.name:(ipconfig.exe OR arp.exe OR netstat.exe OR route.exe OR nslookup.exe OR net.exe OR net1.exe))) AND (NOT ((process.parent.name:(cmd.exe OR powershell.exe OR powershell_ise.exe OR pwsh.exe OR explorer.exe OR WindowsTerminal.exe OR wt.exe OR bash.exe OR cscript.exe OR wscript.exe)) OR (process.parent.executable:(C\:\\Program\ Files\\* OR C\:\\Program\ Files\ \(x86\)\\* OR C\:\\Windows\\System32\\* OR C\:\\Windows\\SysWOW64\\* OR C\:\\Windows\\WinSxS\\*))))