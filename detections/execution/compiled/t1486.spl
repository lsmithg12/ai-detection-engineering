file.extension IN ("locked", "encrypted", "enc", "crypt", "crypto", "ransom", "rnsmw", "pay", "cerber", "locky", "zepto", "odin", "thor", "aesir", "zzzzz", "dharma", "wallet", "onion", "wncry", "wcry", "crab", "lock", "venus", "hive", "royal", "basta", "akira", "blacksuit") process.executable IN ("*\\ProgramData\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*", "*\\Recycle*") NOT (process.executable IN ("*\\Microsoft\\OneDrive\\*", "*\\Microsoft\\Edge\\*", "*\\Google\\Chrome\\*", "*\\Windows Defender\\*", "*\\Microsoft Office\\*", "*\\7-Zip\\*", "*\\WinRAR\\*", "*\\WinZip\\*", "*\\VeraCrypt\\*", "*\\BitLocker\\*")) NOT (file.extension IN ("bak", "tmp", "temp")) | table process.executable,process.name,process.pid,process.parent.name,file.path,file.extension,user.name,host.name