ParentImage IN ("*\\OUTLOOK.EXE", "*\\WINWORD.EXE", "*\\EXCEL.EXE", "*\\POWERPNT.EXE", "*\\MSPUB.EXE", "*\\MSACCESS.EXE", "*\\ONENOTE.EXE", "*\\ONENOTEM.EXE") Image IN ("*\\ProgramData\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Users\\Public\\*", "*\\Downloads\\*", "*\\Temp\\*") NOT (User IN ("*SYSTEM*", "*LOCAL SERVICE*", "*NETWORK SERVICE*")) NOT (Image IN ("*\\MicrosoftEdgeUpdate.exe", "*\\Teams.exe", "*\\OneDrive.exe", "*\\msoia.exe", "*\\ai.exe", "*\\splwow64.exe")) NOT Image="*\\ProgramData\\Microsoft\\*" | table Image,ParentImage,CommandLine,User,host.name,process.hash.sha256