(process.executable:(*\\AppData\\Roaming\\* OR *\\AppData\\Local\\* OR *\\AppData\\Local\\Temp\\* OR *\\Users\\Public\\* OR *\\ProgramData\\* OR *\\Downloads\\* OR *\\Desktop\\*)) AND (process.command_line:(*\-connect\ * OR *\-\-connect\ * OR *\-tunnel\ * OR *\-\-tunnel\ * OR *\-relay\ * OR *\-\-relay\ * OR *\-server\ * OR *\-\-server\ * OR *\-remotehost\ * OR *\-\-remotehost\ * OR *\-target\ *)) AND (NOT (process.executable:(*\\OneDrive.exe OR *\\Teams.exe OR *\\Slack.exe OR *\\Code.exe OR *\\GitHubDesktop.exe OR *\\chrome.exe OR *\\msedge.exe OR *\\firefox.exe OR *\\zoom.exe))) AND (NOT user.name:SYSTEM)