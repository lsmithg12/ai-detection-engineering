(process.executable:*\\cmd.exe AND (process.command_line:*\/c* AND process.command_line:*systeminfo*) AND (process.command_line:(*whoami* OR *hostname* OR *ipconfig* OR *net\ config* OR *wmic\ os*))) AND (NOT (process.parent.executable:(C\:\\Program\ Files\\* OR C\:\\Program\ Files\ \(x86\)\\* OR C\:\\Windows\\System32\\* OR C\:\\Windows\\SysWOW64\\* OR C\:\\ProgramData\\Microsoft\\Windows\ Defender\\*))) AND (NOT user.name:*SYSTEM*)