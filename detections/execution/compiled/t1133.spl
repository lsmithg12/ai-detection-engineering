process.executable IN ("*\\AppData\\Roaming\\*", "*\\AppData\\Local\\*", "*\\AppData\\Local\\Temp\\*", "*\\Users\\Public\\*", "*\\ProgramData\\*", "*\\Downloads\\*", "*\\Desktop\\*") process.command_line IN ("*-connect *", "*--connect *", "*-tunnel *", "*--tunnel *", "*-relay *", "*--relay *", "*-server *", "*--server *", "*-remotehost *", "*--remotehost *", "*-target *") NOT (process.executable IN ("*\\OneDrive.exe", "*\\Teams.exe", "*\\Slack.exe", "*\\Code.exe", "*\\GitHubDesktop.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\firefox.exe", "*\\zoom.exe")) NOT user.name="SYSTEM" | table process.executable,process.command_line,process.parent.executable,user.name,host.name,destination.ip