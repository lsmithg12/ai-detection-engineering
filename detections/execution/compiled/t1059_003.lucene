process.executable:*\\cmd.exe AND ((((process.command_line:*\/c* AND process.command_line:*\&*) AND (process.command_line:(*whoami* OR *net\ user* OR *net\ localgroup* OR *nltest* OR *net\ group* OR *systeminfo* OR *tasklist* OR *query\ user* OR *net\ view* OR *netstat* OR *reg\ query* OR *wmic*))) AND (NOT (process.parent.executable:(C\:\\Program\ Files\\* OR C\:\\Program\ Files\ \(x86\)\\*)))) OR ((process.parent.executable:(*\\ProgramData\\* OR *\\AppData\\* OR *\\Temp\\* OR *\\Users\\Public\\* OR *\\Windows\\Temp\\* OR *\\Downloads\\* OR *\\Recycle*)) AND (NOT (process.parent.executable:(C\:\\Windows\\System32\\* OR C\:\\Windows\\SysWOW64\\* OR C\:\\Windows\\explorer.exe*))) AND (NOT (process.parent.executable:(*\\explorer.exe OR *\\msiexec.exe OR *\\services.exe)))))