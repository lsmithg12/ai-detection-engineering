event.category="process" event.type="start" process.name IN ("ipconfig.exe", "arp.exe", "netstat.exe", "route.exe", "nslookup.exe", "net.exe", "net1.exe") NOT (process.parent.name IN ("cmd.exe", "powershell.exe", "powershell_ise.exe", "pwsh.exe", "explorer.exe", "WindowsTerminal.exe", "wt.exe", "bash.exe", "cscript.exe", "wscript.exe") OR process.parent.executable IN ("C:\\Program Files\\*", "C:\\Program Files (x86)\\*", "C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\WinSxS\\*")) | table process.name,process.command_line,process.executable,process.parent.name,process.parent.executable,user.name,host.name