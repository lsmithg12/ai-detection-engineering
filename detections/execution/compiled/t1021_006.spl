event.code="1" process.name="wmic.exe" process.command_line="*/node:*" process.command_line="*process*" process.command_line="*call*" process.command_line="*create*" NOT (process.parent.name IN ("CcmExec.exe", "ccmexec.exe", "CCMEXEC.EXE") OR process.parent.name IN ("mmc.exe", "wmiadap.exe", "WinMgmt.exe") OR (process.parent.name="WmiPrvSE.exe" process.command_line="*process call create*" user.name="SYSTEM" user.domain="NT AUTHORITY"))