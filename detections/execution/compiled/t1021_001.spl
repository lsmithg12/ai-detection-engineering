(event.code="1" process.name="mstsc.exe" NOT (process.parent.name IN ("explorer.exe", "mmc.exe", "RuntimeBroker.exe", "ServerManager.exe", "mstsc.exe", "rdcman.exe", "WindowsTerminal.exe", "cmd.exe", "powershell.exe", "pwsh.exe")) NOT (process.parent.executable IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Program Files\\*", "C:\\Program Files (x86)\\*"))) OR (event.code="3" process.name="mstsc.exe" destination.port=3389) OR (event.code="11" process.name="mstsc.exe" file.name="*.rdp") | table event.code,process.name,process.executable,process.command_line,process.parent.name,process.parent.executable,destination.ip,destination.port,file.name,file.path,user.name,host.name