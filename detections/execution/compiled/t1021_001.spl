event.code="1" process.name="mstsc.exe" NOT (process.parent.name IN ("explorer.exe", "mmc.exe", "RuntimeBroker.exe", "ServerManager.exe", "mstsc.exe", "rdcman.exe", "WindowsTerminal.exe", "cmd.exe", "powershell.exe", "pwsh.exe")) NOT (process.parent.executable IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Program Files\\*", "C:\\Program Files (x86)\\*")) | table process.command_line,process.parent.name,process.parent.executable,user.name,host.name,destination.ip