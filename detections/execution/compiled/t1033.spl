process.name="whoami.exe" OR (process.name IN ("*\\net.exe", "*\\net1.exe") process.command_line IN ("*/domain*", "*/all*", "*user*", "*localgroup*", "*group*")) process.parent.executable IN ("*\\AppData\\*", "*\\Temp\\*", "*\\ProgramData\\*", "*\\Downloads\\*", "*\\Desktop\\*", "*\\Users\\Public\\*") NOT (process.parent.name IN ("explorer.exe", "svchost.exe", "services.exe", "wininit.exe", "winlogon.exe") process.parent.executable="C:\\Windows\\*") | table process.name,process.command_line,process.executable,process.parent.name,process.parent.executable,user.name,host.name