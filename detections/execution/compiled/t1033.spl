(process.name="whoami.exe" process.command_line="*/all*") OR (process.name="net.exe" process.command_line="*user*" process.command_line="*/domain*") NOT (process.parent.executable IN ("C:\\Windows\\*", "C:\\Program Files\\*", "C:\\Program Files (x86)\\*")) | table process.name,process.command_line,process.parent.name,process.parent.executable,user.name,host.name