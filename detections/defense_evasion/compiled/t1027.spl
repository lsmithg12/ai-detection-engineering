process.name="powershell.exe" process.command_line IN ("*-Enc *", "*-Enc\"*", "*-EncodedCommand *", "*-encodedcommand *", "*-Encoded *", "*-encoded *", "*-ec *") process.command_line IN ("*-W Hidden*", "*-WindowStyle Hidden*", "*-w hidden*", "*-NoP*", "*-nop*", "*-NoProfile*") OR process.parent.executable IN ("*\\AppData\\Roaming\\*", "*\\AppData\\Local\\Temp\\*", "*\\Users\\Public\\*", "*\\ProgramData\\*", "*\\Downloads\\*") NOT (user.name="SYSTEM" process.parent.executable IN ("*\\Windows\\System32\\*", "*\\Windows\\SysWOW64\\*")) NOT (user.name="SYSTEM" process.command_line="*-NonInteractive*" process.parent.name IN ("svchost.exe", "services.exe", "taskeng.exe", "taskhostw.exe"))