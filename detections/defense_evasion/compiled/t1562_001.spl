Parsing Sigma rules
event.code="7" file.name IN ("amsi.dll", "clr.dll") process.executable IN ("*AppData*", "*Temp*", "*ProgramData*", "*Users\\Public*", "*Downloads*") NOT (process.name IN ("powershell.exe", "pwsh.exe", "dotnet.exe", "devenv.exe", "msbuild.exe", "csc.exe", "vbc.exe", "MSBuild.exe")) | table file.name,process.name,process.executable,user.name,host.name
