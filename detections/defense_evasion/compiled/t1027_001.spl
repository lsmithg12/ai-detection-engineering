event.category="process" event.code="1" process.name IN ("*powershell.exe*", "*cmd.exe*") process.command_line="*WriteAllBytes*" process.command_line="*ReadAllBytes*" process.command_line="*New-Object byte[]*" NOT (process.parent.executable IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Program Files\\*", "C:\\Program Files (x86)\\*") process.name IN ("*OneDrive*", "*MicrosoftEdgeUpdate*", "*Teams*", "*MsiExec*")) | table process.command_line,process.executable,process.parent.executable,process.parent.name,user.name,host.name