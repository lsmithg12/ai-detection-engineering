(event.code="1" process.name IN ("*powershell.exe", "*pwsh.exe") process.command_line="*WriteAllBytes*" process.command_line="*New-Object byte[]*") OR (event.code="1" process.name="cmd.exe" process.command_line="*WriteAllBytes*" process.command_line="*New-Object byte[]*") | table process.name,process.executable,process.command_line,process.parent.name,process.parent.executable,user.name,host.name