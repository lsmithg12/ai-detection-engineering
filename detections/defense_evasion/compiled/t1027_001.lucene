((event.category:process AND event.code:1 AND (process.name:(*powershell.exe* OR *cmd.exe*))) AND (process.command_line:*WriteAllBytes* AND process.command_line:*ReadAllBytes* AND process.command_line:*New\-Object\ byte\[\]*)) AND (NOT ((process.parent.executable:(C\:\\Windows\\System32\\* OR C\:\\Windows\\SysWOW64\\* OR C\:\\Program\ Files\\* OR C\:\\Program\ Files\ \(x86\)\\*)) AND (process.name:(*OneDrive* OR *MicrosoftEdgeUpdate* OR *Teams* OR *MsiExec*))))