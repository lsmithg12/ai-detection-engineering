  "expected_detection": {
    "should_alert_on": "attack_sequence",
    "should_not_alert_on": "benign_similar",
    "key_fields": ["process.name", "process.args", "file.path", "user.name"],
    "notes": "Alert on crontab -e by root OR writes to /var/spool/cron/crontabs/. Exclude crontab -l (read-only) and non-root non-system users modifying their own crontabs."
