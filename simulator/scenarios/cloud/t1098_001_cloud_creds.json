          "kind": "event",
          "action": "CreateAccessKey",
          "outcome": "success",
          "provider": "iam.amazonaws.com",
          "dataset": "aws.cloudtrail"
        },
        "cloud": {
          "provider": "aws",
          "account": { "id": "123456789012" },
          "region": "us-east-1",
          "service": { "name": "iam" }
        },
        "source": { "ip": "198.51.100.42" },
        "user": { "name": "bob", "id": "123456789012" },
        "user_agent": { "original": "aws-cli/2.15.0 Python/3.11.0 Linux/5.15.0" },
        "aws": {
          "cloudtrail": {
            "event_type": "AwsApiCall",
            "event_source": "iam.amazonaws.com",
            "event_name": "CreateAccessKey",
            "request_parameters": { "UserName": "admin" },
            "response_elements": {
              "accessKey": {
                "userName": "admin",
                "accessKeyId": "AKIAIOSFODNN7EXAMPLE",
                "status": "Active"
              }
            },
            "user_identity": {
              "type": "IAMUser",
              "user_name": "bob",
              "account_id": "123456789012",
              "arn": "arn:aws:iam::123456789012:user/bob"
            }
          }
        },
        "_simulation": {
          "type": "attack",
          "technique": "T1098.001",
          "platform": "cloud",
          "expected_match": true,
          "sequence_order": 1,
